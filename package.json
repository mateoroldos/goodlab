{
  "name": "goodlab",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "wrangler types --check && vite build",
    "preview": "bun run build && wrangler dev",
    "lint": "prettier --check . && NODE_OPTIONS=--max-old-space-size=4096 eslint .",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync || echo ''",
    "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "bun run build && wrangler deploy --env production",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/eslint-config": "^10.0.0",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/figlet": "^1.7.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/parser": "^8.62.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-svelte": "^3.19.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^4.1.1",
    "shadcn-svelte": "^1.3.0",
    "shiki": "^4.2.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.97.0"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "figlet": "^1.11.0",
    "runed": "^0.37.1"
  }
}
